PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/s-chain
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:5173

# Rate limiting (auth) — optional overrides
# AUTH_LOGIN_MAX=5
# AUTH_LOGIN_WINDOW_MS=900000
# AUTH_REGISTER_MAX=20
# AUTH_REGISTER_WINDOW_MS=3600000
# AUTH_BOOTSTRAP_MAX=3
# AUTH_BOOTSTRAP_WINDOW_MS=3600000

# Behind a reverse proxy, set so X-Forwarded-For is trusted for rate-limit IP
# TRUST_PROXY=1
